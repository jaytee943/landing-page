---
import Button from './Button.astro';
import Container from './Container.astro';
import Eyebrow from './Eyebrow.astro';
import ImagePlaceholder from './ImagePlaceholder.astro';
import { siteConfig } from '../data/site';
---

<Container
  as="section"
  class="grid grid-cols-1 items-center gap-14 pt-[96px] pb-[100px] md:grid-cols-[1.05fr_0.95fr]"
>
  <div>
    <Eyebrow>Individual Therapy &amp; Coaching</Eyebrow>
    <h1
      class="font-display mb-6 max-w-[11ch] text-[52px] leading-[1.14] font-normal tracking-[-0.01em] text-pretty"
    >
      A quiet space to think, feel, and move forward
    </h1>
    <p class="text-ink-muted mb-9 max-w-[46ch] text-lg leading-[1.7] text-pretty">
      I'm {siteConfig.practitionerName}, a licensed therapist and coach helping adults work through
      anxiety, life transitions, and the everyday weight of being a person. Sessions are warm,
      unhurried, and grounded in what actually helps.
    </p>
    <div class="flex flex-wrap items-center gap-4">
      <Button href={siteConfig.schedulerUrl} external>Schedule a free consult</Button>
      <Button href="#services" variant="outline">See services</Button>
    </div>
    <div class="text-ink-soft mt-[52px] flex gap-7 text-[13px]">
      <span>{siteConfig.credential}</span>
      <span class="opacity-50">·</span>
      <span>In-person &amp; virtual</span>
      <span class="opacity-50">·</span>
      <span>Based in {siteConfig.location}</span>
    </div>
  </div>
  <ImagePlaceholder
    label="Portrait of Margaret, warm natural light"
    class="rounded-card relative aspect-[4/5] overflow-hidden shadow-[0_12px_32px_rgba(46,43,37,0.22)]"
  />
</Container>
