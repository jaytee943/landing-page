---
import Button from './Button.astro';
import type { PricingPlan } from '../data/site';
import { DEFAULT_LOCALE } from '../i18n/config';
import { t } from '../i18n/translate';
import { siteConfig } from '../data/site';

interface Props {
  plan: PricingPlan;
}

const { plan } = Astro.props;
const base = `pricing.plans.${plan.id}`;
---

<div
  class:list={[
    'rounded-card relative flex flex-col gap-[18px] border p-10 px-8',
    plan.featured ? 'border-sage-border bg-sage-pale' : 'border-line bg-surface',
  ]}
>
  {
    plan.featured && (
      <div
        data-i18n="pricing.featuredBadge"
        class="bg-accent font-display text-accent-contrast absolute -top-[13px] left-8 rounded-full px-4 py-1.5 text-xs"
      >
        {t(DEFAULT_LOCALE, 'pricing.featuredBadge')}
      </div>
    )
  }
  <h3 class="font-display mt-2 text-xl font-normal" data-i18n={`${base}.title`}>
    {t(DEFAULT_LOCALE, `${base}.title`)}
  </h3>
  <div class="flex items-baseline gap-1.5">
    <span class="font-display text-[34px]">{plan.price}</span>
    <span class="text-ink-soft text-sm" data-i18n={`${base}.unit`}>
      {t(DEFAULT_LOCALE, `${base}.unit`)}
    </span>
  </div>
  <p class="text-ink-muted flex-1 text-[15px] leading-[1.7]" data-i18n={`${base}.desc`}>
    {t(DEFAULT_LOCALE, `${base}.desc`)}
  </p>
  <Button href={siteConfig.schedulerUrl} external class="mt-2 w-full">
    <span data-i18n="pricing.bookThis">{t(DEFAULT_LOCALE, 'pricing.bookThis')}</span>
  </Button>
</div>
