---
import Button from './Button.astro';
import type { PricingPlan } from '../data/site';
import { siteConfig } from '../data/site';

interface Props {
  plan: PricingPlan;
}

const { plan } = Astro.props;
---

<div
  class:list={[
    'rounded-card relative flex flex-col gap-[18px] border p-10 px-8',
    plan.featured ? 'border-sage-border bg-sage-pale' : 'border-line bg-surface',
  ]}
>
  {
    plan.featured && (
      <div class="bg-accent font-display text-accent-contrast absolute -top-[13px] left-8 rounded-full px-4 py-1.5 text-xs">
        Most common
      </div>
    )
  }
  <h3 class="font-display mt-2 text-xl font-normal">{plan.title}</h3>
  <div class="flex items-baseline gap-1.5">
    <span class="font-display text-[34px]">{plan.price}</span>
    <span class="text-ink-soft text-sm">{plan.unit}</span>
  </div>
  <p class="text-ink-muted flex-1 text-[15px] leading-[1.7]">{plan.desc}</p>
  <Button href={siteConfig.schedulerUrl} external class="mt-2 w-full"> Book this </Button>
</div>
