---
import type { ProcessStep } from '../data/site';
import { DEFAULT_LOCALE } from '../i18n/config';
import { t } from '../i18n/translate';

interface Props {
  step: ProcessStep;
}

const { step } = Astro.props;
const base = `process.steps.${step.id}`;
---

<div class="rounded-panel relative bg-white/8 px-[22px] py-6">
  <div class="font-display text-sage-light mb-3.5 text-[15px]">{step.num}</div>
  <h3 class="mb-2.5 text-lg font-bold text-white" data-i18n={`${base}.title`}>
    {t(DEFAULT_LOCALE, `${base}.title`)}
  </h3>
  <p class="text-sage-pale text-sm leading-[1.7] opacity-90" data-i18n={`${base}.desc`}>
    {t(DEFAULT_LOCALE, `${base}.desc`)}
  </p>
</div>
