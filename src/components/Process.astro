---
import ProcessStepCard from './ProcessStepCard.astro';
import { processSteps } from '../data/site';
---

<section id="process" class="process">
  <div class="process__inner">
    <div class="process__intro">
      <p class="eyebrow eyebrow--on-dark">How it works</p>
      <h2 class="section-heading process__heading">A simple, unhurried process</h2>
    </div>
    <div class="process__grid">
      {processSteps.map((step) => <ProcessStepCard step={step} />)}
    </div>
  </div>
</section>

<style>
  .process {
    padding: 110px var(--gutter);
    background: var(--color-green-mid);
    color: var(--color-green-pale);
  }

  .process__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .process__intro {
    max-width: 640px;
    margin: 0 0 72px;
  }

  .process__heading {
    font-size: 36px;
    margin: 0;
    color: #fff;
  }

  .process__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }

  @media (max-width: 960px) {
    .process__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .process__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
