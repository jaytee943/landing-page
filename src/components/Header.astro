---
import Button from './Button.astro';
import { siteConfig } from '../data/site';

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#services', label: 'Services' },
  { href: '#process', label: 'Process' },
  { href: '#pricing', label: 'Pricing' },
];
---

<header
  class="border-line-hairline bg-bg/92 sticky top-0 z-50 flex items-center justify-between border-b px-[6vw] py-[22px] backdrop-blur-[8px]"
>
  <div class="font-display text-ink text-[22px]">{siteConfig.businessName}</div>
  <nav class="flex items-center gap-9 text-[15px]">
    <div class="flex gap-8">
      {
        navLinks.map((link) => (
          <a href={link.href} class="text-ink">
            {link.label}
          </a>
        ))
      }
    </div>
    <Button href={siteConfig.schedulerUrl} size="sm" external> Book a session </Button>
  </nav>
</header>
