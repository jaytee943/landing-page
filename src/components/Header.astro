---
import Button from './Button.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { DEFAULT_LOCALE } from '../i18n/config';
import { t } from '../i18n/translate';
import { siteConfig } from '../data/site';

const navLinks = [
  { href: '#about', key: 'nav.about' },
  { href: '#services', key: 'nav.services' },
  { href: '#process', key: 'nav.process' },
  { href: '#pricing', key: 'nav.pricing' },
];
---

<header
  class="border-line-hairline bg-bg/92 sticky top-0 z-50 flex items-center justify-between border-b px-[6vw] py-[22px] backdrop-blur-[8px]"
>
  <div class="font-display text-ink text-[22px]">{siteConfig.businessName}</div>
  <nav class="flex items-center gap-9 text-[15px]">
    <div class="flex gap-8">
      {
        navLinks.map((link) => (
          <a href={link.href} class="text-ink" data-i18n={link.key}>
            {t(DEFAULT_LOCALE, link.key)}
          </a>
        ))
      }
    </div>
    <LanguageSwitcher />
    <Button href={siteConfig.schedulerUrl} size="sm" external>
      <span data-i18n="nav.bookSession">{t(DEFAULT_LOCALE, 'nav.bookSession')}</span>
    </Button>
  </nav>
</header>
