---
interface Props {
  label: string;
  i18nKey?: string;
  class?: string;
}

const { label, i18nKey, class: className } = Astro.props;
---

<div class={className}>
  <div
    role="img"
    aria-label={label}
    data-i18n={i18nKey}
    data-i18n-attr={i18nKey ? 'aria-label' : undefined}
    class="border-line bg-bg-alt/60 text-ink-soft flex h-full w-full items-center justify-center border-2 border-dashed p-6 text-center text-[13px]"
  >
    {label}
  </div>
</div>
