---
import { DEFAULT_LOCALE } from '../i18n/config';
import { t } from '../i18n/translate';

interface Props {
  i18nKey: string;
  as?: 'h1' | 'h2';
  class?: string;
}

const { i18nKey, as: Tag = 'h2', class: className }: Props = Astro.props;
---

<Tag data-i18n={i18nKey} class:list={['font-display font-normal', className]}>
  {t(DEFAULT_LOCALE, i18nKey)}
</Tag>
