---
import { siteConfig } from '../data/site';

const year = new Date().getFullYear();
const credentialAbbr = siteConfig.credential.split(',')[0];
const copyrightLine = `© ${year} ${siteConfig.practitionerName}, ${credentialAbbr}. All sessions confidential.`;
---

<footer
  class="border-line-hairline text-ink-soft flex flex-wrap items-center justify-between gap-3 border-t px-[6vw] py-10 text-[13px]"
>
  <div class="font-display text-ink text-base">{siteConfig.businessName}</div>
  <div>{copyrightLine}</div>
</footer>
