---
import type { Service } from '../data/site';

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<div class="service-card" style={`--tint:${service.tint};--icon-color:${service.iconColor}`}>
  <div class="service-card__icon">
    <div class="service-card__icon-dot"></div>
  </div>
  <h3 class="service-card__title">{service.title}</h3>
  <p class="service-card__desc">{service.desc}</p>
  <div class="service-card__meta">{service.meta}</div>
</div>

<style>
  .service-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 36px 30px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: 0 1px 2px rgba(46, 43, 37, 0.14);
  }

  .service-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--tint);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-card__icon-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--icon-color);
  }

  .service-card__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 20px;
    margin: 6px 0 0;
  }

  .service-card__desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0;
    flex: 1;
  }

  .service-card__meta {
    font-size: 13px;
    color: var(--color-green);
    font-weight: 600;
    padding-top: 8px;
    border-top: 1px solid var(--color-border);
  }
</style>
