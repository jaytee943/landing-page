---
import type { Service } from '../data/site';
import { DEFAULT_LOCALE } from '../i18n/config';
import { t } from '../i18n/translate';

interface Props {
  service: Service;
}

const { service } = Astro.props;
const base = `services.items.${service.id}`;
---

<div
  class="rounded-card border-line bg-surface flex flex-col gap-4 border p-9 px-8 shadow-[0_1px_2px_rgba(46,43,37,0.14)]"
>
  <div
    class="flex h-12 w-12 items-center justify-center rounded-full"
    style={`background:${service.tint}`}
  >
    <div class="h-4 w-4 rounded-full" style={`background:${service.iconColor}`}></div>
  </div>
  <h3 class="font-display mt-1.5 text-xl font-normal" data-i18n={`${base}.title`}>
    {t(DEFAULT_LOCALE, `${base}.title`)}
  </h3>
  <p class="text-ink-muted flex-1 text-[15px] leading-[1.7]" data-i18n={`${base}.desc`}>
    {t(DEFAULT_LOCALE, `${base}.desc`)}
  </p>
  <div
    class="border-line text-sage border-t pt-2 text-[13px] font-semibold"
    data-i18n={`${base}.meta`}
  >
    {t(DEFAULT_LOCALE, `${base}.meta`)}
  </div>
</div>
