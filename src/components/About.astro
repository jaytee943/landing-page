---
import Container from './Container.astro';
import Eyebrow from './Eyebrow.astro';
import ImagePlaceholder from './ImagePlaceholder.astro';
import SectionHeading from './SectionHeading.astro';

const stats = [
  { value: '12+', label: 'Years in practice' },
  { value: 'LMFT', label: 'Licensed & certified' },
  { value: '1:1', label: 'Individual focus only' },
];
---

<section id="about" class="bg-bg-alt py-[100px]">
  <Container class="grid grid-cols-1 items-start gap-16 md:grid-cols-[0.8fr_1.2fr]">
    <ImagePlaceholder
      label="Office / studio setting"
      class="rounded-card relative aspect-square overflow-hidden shadow-[0_12px_32px_rgba(46,43,37,0.22)]"
    />
    <div>
      <Eyebrow>About</Eyebrow>
      <SectionHeading class="mb-6 max-w-[16ch] text-[36px]">
        Therapy that fits into a real life, not around it
      </SectionHeading>
      <p class="text-ink-muted mb-5 max-w-[60ch] text-[16.5px] leading-[1.8]">
        I've spent the last twelve years working with adults navigating anxiety, burnout, grief, and
        the kind of transitions that don't come with a manual — new careers, new relationships,
        becoming a parent, losing one. My approach blends talk therapy with practical coaching, so
        sessions leave you with both understanding and something to actually do.
      </p>
      <p class="text-ink-muted mb-8 max-w-[60ch] text-[16.5px] leading-[1.8]">
        I trained at Duke University and hold licensure as a Marriage &amp; Family Therapist, with
        additional certification in mindfulness-based cognitive coaching. Outside of sessions you'll
        usually find me hiking or in the garden — both show up in how I think about growth.
      </p>
      <div class="mt-3 grid max-w-[480px] grid-cols-3 gap-7">
        {
          stats.map((stat) => (
            <div>
              <div class="font-display text-accent-dark text-[26px]">{stat.value}</div>
              <div class="text-ink-soft mt-1 text-[13px]">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
