---
import Container from './Container.astro';
import Eyebrow from './Eyebrow.astro';
import ImagePlaceholder from './ImagePlaceholder.astro';
import SectionHeading from './SectionHeading.astro';
import { DEFAULT_LOCALE } from '../i18n/config';
import { t } from '../i18n/translate';
import { siteConfig } from '../data/site';

const stats = [
  { value: `${siteConfig.yearsInPractice}+`, key: 'about.statsYears' },
  { value: siteConfig.credentialAbbr, key: 'about.statsLicensed' },
  { value: '1:1', key: 'about.statsFocus' },
];
---

<section id="about" class="bg-bg-alt py-[100px]">
  <Container class="grid grid-cols-1 items-start gap-16 md:grid-cols-[0.8fr_1.2fr]">
    <ImagePlaceholder
      label={t(DEFAULT_LOCALE, 'about.photoAlt')}
      i18nKey="about.photoAlt"
      class="rounded-card relative aspect-square overflow-hidden shadow-[0_12px_32px_rgba(46,43,37,0.22)]"
    />
    <div>
      <Eyebrow i18nKey="about.eyebrow" />
      <SectionHeading i18nKey="about.heading" class="mb-6 max-w-[16ch] text-[36px]" />
      <p
        data-i18n="about.paragraph1"
        class="text-ink-muted mb-5 max-w-[60ch] text-[16.5px] leading-[1.8]"
      >
        {t(DEFAULT_LOCALE, 'about.paragraph1')}
      </p>
      <p
        data-i18n="about.paragraph2"
        class="text-ink-muted mb-8 max-w-[60ch] text-[16.5px] leading-[1.8]"
      >
        {t(DEFAULT_LOCALE, 'about.paragraph2')}
      </p>
      <div class="mt-3 grid max-w-[480px] grid-cols-3 gap-7">
        {
          stats.map((stat) => (
            <div>
              <div class="font-display text-accent-dark text-[26px]">{stat.value}</div>
              <div class="text-ink-soft mt-1 text-[13px]" data-i18n={stat.key}>
                {t(DEFAULT_LOCALE, stat.key)}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
